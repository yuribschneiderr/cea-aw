{
  "datasets": [
    {
      "name": "ds_kpi_01",
      "displayName": "Total de Pedidos",
      "query": "SELECT COUNT(DISTINCT fk_pedido_venda) AS total_pedidos FROM fct_pedidos_vendas"
    },
    {
      "name": "ds_kpi_02",
      "displayName": "Total de Itens Comprados",
      "query": "SELECT SUM(quantidade) AS total_itens_comprados FROM fct_pedidos_vendas"
    },
    {
      "name": "ds_kpi_03",
      "displayName": "Valor Total Negociado",
      "query": "SELECT SUM(quantidade * preco_unitario) AS valor_total_negociado FROM fct_pedidos_vendas"
    },
    {
      "name": "ds_bar_01",
      "displayName": "Faturamento por Produto Top 15",
      "query": "SELECT p.nome_produto AS produto, SUM(f.quantidade * f.preco_unitario) AS faturamento_total FROM fct_pedidos_vendas f JOIN dim_produtos p ON f.fk_produto = p.pk_produto GROUP BY p.nome_produto ORDER BY faturamento_total DESC LIMIT 15"
    },
    {
      "name": "ds_bar_02",
      "displayName": "Faturamento por Tipo de Cartao",
      "query": "SELECT tipo_cartao AS cartao, SUM(quantidade * preco_unitario) AS faturamento_total FROM fct_pedidos_vendas GROUP BY tipo_cartao ORDER BY faturamento_total DESC"
    },
    {
      "name": "ds_bar_03",
      "displayName": "Faturamento por Motivo de Venda",
      "query": "SELECT motivos_venda AS motivo, SUM(quantidade * preco_unitario) AS faturamento_total FROM fct_pedidos_vendas GROUP BY motivos_venda ORDER BY faturamento_total DESC"
    },
    {
      "name": "ds_bar_04",
      "displayName": "Faturamento por Status do Pedido",
      "query": "SELECT CASE status_pedido WHEN 1 THEN 'Em Processamento' WHEN 2 THEN 'Aprovado' WHEN 3 THEN 'Atrasado' WHEN 4 THEN 'Rejeitado' WHEN 5 THEN 'Enviado' WHEN 6 THEN 'Cancelado' ELSE 'Desconhecido' END AS status, SUM(quantidade * preco_unitario) AS faturamento_total FROM fct_pedidos_vendas GROUP BY status_pedido ORDER BY faturamento_total DESC"
    },
    {
      "name": "ds_geo_01",
      "displayName": "Faturamento por Pais e Estado",
      "query": "SELECT c.pais, c.estado, SUM(f.quantidade * f.preco_unitario) AS faturamento_total FROM fct_pedidos_vendas f JOIN dim_clientes c ON f.fk_cliente = c.pk_cliente GROUP BY c.pais, c.estado ORDER BY faturamento_total DESC"
    },
    {
      "name": "ds_line_01",
      "displayName": "Ticket Medio Mensal",
      "query": "WITH pedidos_agrupados AS (SELECT d.ano_mes, f.fk_pedido_venda, SUM(f.quantidade * f.preco_unitario) AS valor_pedido FROM fct_pedidos_vendas f JOIN dim_datas d ON f.fk_data = d.pk_data GROUP BY d.ano_mes, f.fk_pedido_venda) SELECT ano_mes AS mes, AVG(valor_pedido) AS ticket_medio FROM pedidos_agrupados GROUP BY ano_mes ORDER BY mes"
    },
    {
      "name": "ds_top_01",
      "displayName": "Top 10 Clientes",
      "query": "SELECT c.nome_cliente AS cliente, SUM(f.quantidade * f.preco_unitario) AS faturamento_total FROM fct_pedidos_vendas f JOIN dim_clientes c ON f.fk_cliente = c.pk_cliente GROUP BY c.nome_cliente ORDER BY faturamento_total DESC LIMIT 10"
    },
    {
      "name": "ds_top_02",
      "displayName": "Top 5 Cidades",
      "query": "SELECT c.cidade AS cidade, SUM(f.quantidade * f.preco_unitario) AS faturamento_total FROM fct_pedidos_vendas f JOIN dim_clientes c ON f.fk_cliente = c.pk_cliente GROUP BY c.cidade ORDER BY faturamento_total DESC LIMIT 5"
    },
    {
      "name": "ds_time_01",
      "displayName": "Serie Temporal Vendas",
      "query": "SELECT d.ano_mes AS mes, COUNT(DISTINCT f.fk_pedido_venda) AS total_pedidos, SUM(f.quantidade * f.preco_unitario) AS faturamento_total FROM fct_pedidos_vendas f JOIN dim_datas d ON f.fk_data = d.pk_data GROUP BY d.ano_mes ORDER BY mes"
    },
    {
      "name": "ds_promo_01",
      "displayName": "Produto Mais Vendido em Promocoes",
      "query": "SELECT p.nome_produto AS produto, SUM(f.quantidade) AS total_vendido FROM fct_pedidos_vendas f JOIN dim_produtos p ON f.fk_produto = p.pk_produto WHERE f.motivos_venda LIKE '%Promotion%' GROUP BY p.nome_produto ORDER BY total_vendido DESC LIMIT 10"
    }
  ],
